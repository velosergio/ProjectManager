# =============================================================================
# PROJECT MANAGER — Environment Variables Contract
# =============================================================================
# Copy this file to .env.local for local development.
# Never commit .env.local or any file with real secrets to version control.
#
# Usage:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE — MySQL (via Prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker default: mysql://root:root@localhost:3306/project_manager
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://root:root@localhost:3306/project_manager"

# -----------------------------------------------------------------------------
# AUTH — NextAuth.js
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: must match the app's public URL
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (optional — add as needed)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# REDIS — Cache / Queues / Notifications
# Format: redis://HOST:PORT
# Docker default: redis://localhost:6379
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# MINIO — Object Storage (S3-compatible)
# Docker default endpoint: http://localhost:9000
# -----------------------------------------------------------------------------
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="project-manager"

# -----------------------------------------------------------------------------
# EMAIL (optional — for password reset / notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@projectmanager.local"
