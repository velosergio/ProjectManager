// =============================================================================
// Prisma Schema — Project Manager
// Docs: https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference
//
// FASE 1 — Core multitenant: aislamiento por `tenantId`, planes/suscripciones,
// roles globales (admin/mango) y recuperación de contraseña.
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  MANGO
  MANAGER
  MEMBER
  VIEWER
}

/// Estado del miembro (↔ activo / invitado / inactivo). `SUSPENDED` queda
/// reservado, sin uso en la FASE 4.
enum UserStatus {
  ACTIVE
  /// Creado por invitación; sin contraseña hasta aceptar el enlace.
  INVITED
  INACTIVE
  SUSPENDED
}

/// Alcance contextual único de una nota (FASE 4, FR-016/FR-017).
enum NoteScope {
  GLOBAL
  PROJECT
  TASK
  TEAM
}

/// Código estable del plan de suscripción.
enum PlanCode {
  GRATUITO
  PRO
  PRO_PLUS
}

/// Ciclo de facturación de la suscripción.
enum BillingCycle {
  MONTHLY
  YEARLY
}

/// Estado de la suscripción (↔ activa / en_prueba / vencida / cancelada).
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

/// Estado de una tarea de trabajo.
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

/// Estado de un proyecto (alineado con el tablero Kanban de la FASE 3).
/// UI: Pendiente / En proceso / En revisión / Finalizado / Archivado.
enum ProjectStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  ARCHIVED
}

/// Prioridad de un proyecto. UI: Baja / Media / Alta / Urgente.
enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// =============================================================================
// MULTITENANCY — Organización, planes y suscripciones
// =============================================================================

/// Organización (tenant): unidad de aislamiento. Su `id` es el discriminador
/// `tenantId` referenciado por todas las entidades de negocio.
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  subscription Subscription?
  clients      Client[]
  projects     Project[]
  processes    Process[]
  tasks        Task[]
  files        FileAsset[]
  events       Event[]
  tags         Tag[]
  processTypes ProcessType[]
  teams        Team[]
  notes        Note[]

  @@map("tenants")
}

/// Definición parametrizable de un nivel de servicio. Las cuotas son columnas
/// nullable: `null` = ilimitado. Las features viven en config (no en la DB).
model Plan {
  id              String   @id @default(cuid())
  code            PlanCode @unique
  name            String
  /// Precio mensual en COP (Gratuito = 0).
  priceMonthly    Int      @default(0)
  /// Precio anual en COP (con descuento).
  priceYearly     Int      @default(0)
  /// Cuota de proyectos; null = ilimitado.
  maxProjects     Int?
  /// Cuota de usuarios; null = ilimitado.
  maxUsers        Int?
  /// Cuota de almacenamiento en bytes; null = ilimitado.
  maxStorageBytes BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

/// Vínculo vigente entre una organización y un plan (1:1 con Tenant en FASE 1).
model Subscription {
  id               String             @id @default(cuid())
  tenantId         String             @unique
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  cycle            BillingCycle       @default(MONTHLY)
  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("subscriptions")
}

// =============================================================================
// AUTH — Usuario y modelos del adapter de NextAuth
// =============================================================================

/// Usuario de la aplicación. `role = MANGO ⟺ tenantId = null` (acceso global).
model User {
  id       String     @id @default(cuid())
  name     String
  email    String     @unique
  /// Hash bcrypt — null solo si usara OAuth.
  password String?
  image    String?
  role     UserRole   @default(ADMIN)
  status   UserStatus @default(ACTIVE)
  /// Organización del usuario. Null para el super usuario `mango`.
  tenantId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts               Account[]
  sessions               Session[]
  assignedTasks          Task[]
  ownedProjects          Project[]            @relation("ProjectOwner")
  passwordResetTokens    PasswordResetToken[]
  notificationPreference NotificationPreference?
  teams                  Team[]
  notesAuthored          Note[]
  invitationTokens       InvitationToken[]

  @@index([tenantId])
  @@map("users")
}

/// OAuth account linked to a User (NextAuth adapter model).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Active session for a User (NextAuth adapter model).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// Email verification tokens (NextAuth adapter model).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Token de un solo uso para recuperación de contraseña. Solo se almacena el
/// hash del token, nunca el valor en claro.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Token de activación de un miembro invitado (FASE 4). Espejo de
/// PasswordResetToken: un solo uso, caducidad 7 días, solo se persiste el hash.
model InvitationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("invitation_tokens")
}

/// Preferencias de notificación del usuario (1:1 con User). Los defaults dejan
/// al usuario suscrito a avisos y recordatorios, y fuera de novedades de producto.
model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  /// Avisos por correo sobre actividad de su cuenta/proyectos.
  emailAlerts    Boolean  @default(true)
  /// Novedades de producto y anuncios.
  productUpdates Boolean  @default(false)
  /// Recordatorios de tareas próximas a vencer.
  taskReminders  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// =============================================================================
// NEGOCIO — Entidades escopadas por tenant
// =============================================================================

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects Project[]
  tags     Tag[]

  @@index([tenantId])
  @@map("clients")
}

model Project {
  id            String          @id @default(cuid())
  tenantId      String
  clientId      String?
  name          String
  description   String?         @db.Text
  status        ProjectStatus   @default(PENDING)
  priority      ProjectPriority @default(MEDIUM)
  /// Fecha de inicio del proyecto.
  startDate     DateTime?
  /// Fecha de cierre estimada; `endDate >= startDate` se valida en la capa Zod.
  endDate       DateTime?
  /// Responsable del proyecto; «sin asignar» si el usuario desaparece.
  ownerId       String?
  /// Tipo del catálogo del tenant; «sin tipo» si el tipo se elimina.
  processTypeId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner       User?        @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  processType ProcessType? @relation(fields: [processTypeId], references: [id], onDelete: SetNull)
  tags        Tag[]
  processes   Process[]
  files       FileAsset[]
  events      Event[]
  notes       Note[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([clientId])
  @@index([ownerId])
  @@index([processTypeId])
  @@map("projects")
}

/// Etiqueta propia de la organización: catálogo único que clasifica proyectos
/// (FASE 2, FR-013) y clientes (FASE 3, FR-011).
model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects Project[]
  clients  Client[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

/// Tipo de proceso del catálogo de la organización (FR-021).
model ProcessType {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("process_types")
}

model Process {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([tenantId])
  @@index([projectId])
  @@map("processes")
}

model Task {
  id          String     @id @default(cuid())
  tenantId    String
  processId   String
  assigneeId  String?
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  process  Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  notes    Note[]

  @@index([tenantId])
  @@index([processId])
  @@index([assigneeId])
  @@map("tasks")
}

model FileAsset {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  name      String
  path      String
  sizeBytes BigInt   @default(0)
  mimeType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([projectId])
  @@map("file_assets")
}

model Event {
  id        String    @id @default(cuid())
  tenantId  String
  projectId String?
  title     String
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([projectId])
  @@map("events")
}

/// Equipo de trabajo de la organización (FASE 4). Membresía M:N implícita
/// con User; sin atributos propios de membresía en esta fase.
model Team {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members User[]
  notes   Note[]

  @@index([tenantId])
  @@map("teams")
}

/// Nota con alcance contextual único (FASE 4). La invariante XOR
/// alcance ↔ referencia se valida en la capa de negocio (src/lib/notes).
model Note {
  id        String    @id @default(cuid())
  tenantId  String
  scope     NoteScope
  title     String
  content   String    @db.Text
  projectId String?
  taskId    String?
  teamId    String?
  /// Autor; «autor eliminado» si el usuario desaparece (desactivar no borra).
  authorId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  team    Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author  User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tenantId, updatedAt])
  @@index([projectId])
  @@index([taskId])
  @@index([teamId])
  @@map("notes")
}
